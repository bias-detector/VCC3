# Service identity for demo labels
SERVICE_NAME=VCC-3 Local VM

# Local self-hosted LLM config (Ollama recommended)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=20

# Routing/scaling behavior
MAX_LOCAL_CONCURRENCY=4
MAX_LOCAL_QUEUE=20
OFFLOAD_QUEUE_THRESHOLD=8
LOCAL_WAIT_TIMEOUT_SECONDS=8

# Optional cloud fallback target (set this only on local VM)
# Example: http://34.123.45.67:8000
CLOUD_BACKEND_URL=

# UI-friendly URLs
PUBLIC_BASE_URL=http://127.0.0.1:8000
